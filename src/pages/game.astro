---
import Layout from '../layouts/Layout.astro';
import UnitedWordsCoalitionGame from '../components/Game/UnitedWordsCoalitionGame.jsx';
---

<Layout title="David M. Pham — United Words Coalition">
  <div class="uwc-theme">
    <div class="container mx-auto px-4 py-10 max-w-md">
      <div class="uwc-panel px-5 py-4 mb-6 text-center">
        <h1 class="uwc-title text-2xl mb-2">United Words Coalition</h1>
        <p class="uwc-subtitle text-sm">
          Spell words to claim tiles. Surround your tiles to lock them. Highest score wins.
          Earn a letter choice every 5 flips (max 3) to replace any unlocked tile.
        </p>
      </div>
      <UnitedWordsCoalitionGame client:load />
    </div>
  </div>
</Layout>
